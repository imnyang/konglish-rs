{
  "name": "konglish",
  "version": "0.0.1",
  "description": "Konglish - Korean/English transliteration library",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup --config tsup.config.ts",
    "clean": "rm -rf dist",
    "lint": "biome check .",
    "format": "biome format --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "pnpm clean && pnpm build"
  },
  "keywords": [
    "konglish",
    "korean",
    "english",
    "transliteration"
  ],
  "author": "oyc0401",
  "repository": {
    "type": "git",
    "url": "https://github.com/oyc0401/konglish"
  },
  "bugs": {
    "url": "https://github.com/oyc0401/konglish/issues"
  },
  "homepage": "https://github.com/oyc0401/konglish#readme",
  "license": "MIT",
  "dependencies": {
    "cmu-pronouncing-dictionary": "^3.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.0.6",
    "@types/node": "^20.11.5",
    "ts-node": "^10.9.2",
    "tsup": "^7.2.0",
    "typescript": "^5.3.3",
    "vitest": "^1.2.2"
  }
}
